{
  "name": "mindgraph-notes",
  "version": "0.8.14",
  "description": "Lokaler Workspace, der dir täglich zeigt, was in deinen Notizen, Aufgaben und E-Mails wichtig ist — mit Wissensgraph und KI.",
  "main": "out/main/index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron .",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "prebuild": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:signer": "node scripts/build-signer.mjs",
    "rag:eval": "node scripts/run-ts.mjs scripts/rag-eval.ts"
  },
  "keywords": [
    "markdown",
    "notes",
    "graph",
    "electron"
  ],
  "author": {
    "name": "Jochen Leeder",
    "email": "info@bydb.io"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/bydb/mindgraph-notes.git"
  },
  "build": {
    "appId": "com.mindgraph.notes",
    "productName": "MindGraph Notes",
    "generateUpdatesFilesForAllChannels": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      },
      {
        "from": "../CHANGELOG.md",
        "to": "CHANGELOG.md"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "bydb",
      "repo": "mindgraph-notes"
    },
    "mac": {
      "artifactName": "MindGraph-Notes-${version}-${arch}.${ext}",
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": false,
      "extendInfo": {
        "NSCalendarsUsageDescription": "MindGraph Notes zeigt deine Termine im Dashboard und legt Timeblocks für Aufgaben in deinem Kalender an.",
        "NSCalendarsFullAccessUsageDescription": "MindGraph Notes zeigt deine Termine im Dashboard und legt Timeblocks für Aufgaben in deinem Kalender an.",
        "NSMicrophoneUsageDescription": "MindGraph Notes nutzt das Mikrofon, um Diktate lokal in Text umzuwandeln.",
        "NSAppleEventsUsageDescription": "MindGraph Notes kann optional mit Kalender und Erinnerungen interagieren.",
        "NSRemindersUsageDescription": "MindGraph Notes kann optional Aufgaben mit Apple Reminders synchronisieren."
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MindGraph Notes"
    },
    "linux": {
      "icon": "resources/icons/linux",
      "target": [
        "AppImage",
        "deb",
        "snap"
      ],
      "category": "Office"
    },
    "snap": {
      "confinement": "classic",
      "summary": "Local workspace that surfaces what matters today across notes, tasks and email",
      "plugs": [
        "default",
        "removable-media"
      ]
    }
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/dompurify": "^3.0.5",
    "@types/mailparser": "^3.4.6",
    "@types/markdown-it": "^14.1.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@types/ws": "^8.5.13",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.11",
    "@huggingface/transformers": "^4.2.0",
    "@types/react-window": "^1.8.8",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.1.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "ajv": "^6.14.0",
    "chokidar": "^5.0.0",
    "docx": "^9.6.1",
    "dompurify": "^3.3.1",
    "electron-updater": "^6.8.3",
    "grammy": "^1.42.0",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "imapflow": "^1.2.9",
    "jszip": "^3.10.1",
    "katex": "^0.16.27",
    "mailparser": "^3.9.3",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.12.2",
    "node-pty": "^1.1.0",
    "nodemailer": "^9.0.1",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-pdf": "^10.3.0",
    "react-window": "^2.2.5",
    "reactflow": "^11.11.4",
    "sql.js": "^1.13.0",
    "tar": "^7.5.19",
    "turndown": "^7.2.4",
    "ws": "^8.18.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xterm": "^5.3.0",
    "zustand": "^5.0.10"
  }
}
